{
    "name": "wunderio/client-fi-luvn-cms",
    "description": "Luvn.fi Drupal content management.",
    "type": "project",
    "license": "GPL-2.0-or-later",
    "authors": [
        {
            "name": "Jan Lindstr\u00f6m <jan.lindstrom@wunder.io>",
            "role": "Developer"
        },
        {
            "name": "Tomi Mikola <tomi.mikola@wunder.io>",
            "role": "Developer"
        },
        {
            "name": "Marika L\u00e4hde <marika.lahde@wunder.io>",
            "role": "Developer"
        }
    ],
    "repositories": [
        {
            "type": "composer",
            "url": "https://packages.drupal.org/8"
        },
        {
            "type": "vcs",
            "url": "https://github.com/vermario/drupal-codeception"
        }
    ],
    "require": {
        "php": ">=8.1",
        "composer/installers": "^1.8",
        "cweagans/composer-patches": "^1.6",
        "drupal/admin_toolbar": "^3.1",
        "drupal/allowed_formats": "^2.0",
        "drupal/bartik": "^1.0",
        "drupal/cdn": "^4.0",
        "drupal/ckeditor": "^1.0",
        "drupal/config_ignore": "^2.4",
        "drupal/config_split": "^1.7",
        "drupal/content_lock": "^2.2",
        "drupal/core-composer-scaffold": "^10",
        "drupal/core-project-message": "^10",
        "drupal/core-recommended": "^10",
        "drupal/cshs": "^4.0",
        "drupal/diff": "^1.1",
        "drupal/elasticsearch_helper": "7.x-dev",
        "drupal/entity_usage": "^2.0@beta",
        "drupal/external_data_source": "^3.1",
        "drupal/field_group": "^3.1",
        "drupal/flood_control": "^2.2",
        "drupal/form_options_attributes": "^2.0",
        "drupal/imagemagick": "^3.4.0",
        "drupal/link_description": "^1.0@beta",
        "drupal/linkit": "^6.0",
        "drupal/mail_login": "^2.0",
        "drupal/memcache": "^2.5",
        "drupal/menu_migration": "^2.0@alpha",
        "drupal/migrate_drupal_d8": "^1.0",
        "drupal/migrate_file": "^2.1",
        "drupal/migrate_plus": "^6.0",
        "drupal/migrate_tools": "^6.0",
        "drupal/multiple_select": "^2.0.4",
        "drupal/multiple_selects": "^1.0",
        "drupal/node_edit_protection": "^1.0",
        "drupal/node_revision_delete": "^1.0@RC",
        "drupal/noreqnewpass": "^1.2",
        "drupal/openid_connect": "^3.0@alpha",
        "drupal/openid_connect_windows_aad": "^2.0@beta",
        "drupal/paragraphs": "^1.12",
        "drupal/password_policy": "^4.0",
        "drupal/pathauto": "^1.8",
        "drupal/quick_node_clone": "^1.16",
        "drupal/rdf": "^2.1",
        "drupal/redirect": "^1.8.0",
        "drupal/scheduler": "^1.3",
        "drupal/seven": "^1.0",
        "drupal/simple_sitemap": "^4.1",
        "drupal/simplei": "^2.1",
        "drupal/sophron": "^1.2.0",
        "drupal/stage_file_proxy": "^2.0",
        "drupal/svg_image": "^3.0",
        "drupal/title_length": "^2.0@RC",
        "drupal/upgrade_status": "^4.0@alpha",
        "drupal/user_redirect": "^2.0",
        "drupal/view_unpublished": "^1.1",
        "drupal/views_conditional": "^1.4",
        "drush/drush": "^12",
        "elasticsearch/elasticsearch": "~7.0",
        "suin/php-rss-writer": "^1.6",
        "vlucas/phpdotenv": "^5.5",
        "webflo/drupal-finder": "^1.2"
    },
    "require-dev": {
        "codeception/codeception": "^5",
        "codeception/module-asserts": "^3",
        "codeception/module-phpbrowser": "^3",
        "codeception/module-rest": "^3",
        "drupal/core-dev": "^10",
        "palantirnet/drupal-rector": "^0.15.1",
        "wunderio/code-quality": "^2.1.0",
        "wunderio/drupal-codeception": "10.x-dev",
        "zaporylie/composer-drupal-optimizations": "^1.1"
    },
    "conflict": {
        "drupal/drupal": "*"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "sort-packages": true,
        "discard-changes": true,
        "allow-plugins": {
            "composer/installers": true,
            "koodimonni/composer-dropin-installer": true,
            "phpro/grumphp": true,
            "cweagans/composer-patches": true,
            "drupal/core-composer-scaffold": true,
            "zaporylie/composer-drupal-optimizations": true,
            "drupal/core-project-message": true,
            "phpstan/extension-installer": true,
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    },
    "autoload": {
        "classmap": [
            "scripts/composer/ScriptHandler.php"
        ],
        "files": [
            "load.environment.php"
        ]
    },
    "scripts": {
        "post-install-cmd": [
            "DrupalProject\\composer\\ScriptHandler::createRequiredFiles"
        ],
        "post-update-cmd": [
            "DrupalProject\\composer\\ScriptHandler::createRequiredFiles"
        ]
    },
    "extra": {
        "drupal-scaffold": {
            "locations": {
                "web-root": "./web"
            }
        },
        "installer-paths": {
            "web/core": [
                "type:drupal-core"
            ],
            "web/libraries/{$name}": [
                "type:drupal-library"
            ],
            "web/modules/contrib/{$name}": [
                "type:drupal-module"
            ],
            "web/profiles/contrib/{$name}": [
                "type:drupal-profile"
            ],
            "web/themes/contrib/{$name}": [
                "type:drupal-theme"
            ],
            "drush/Commands/{$name}": [
                "type:drupal-drush"
            ]
        },
        "composer-exit-on-patch-failure": true,
        "patches": {
            "drupal/core": {
                "Can only intentionally re-render an entity with references 20 times | https://www.drupal.org/node/2940605": "https://www.drupal.org/files/issues/2022-10-21/2940605-100.patch",
                "Call to a member function setSyncing() on null when installing a module | https://www.drupal.org/i/3051453": "https://www.drupal.org/files/issues/2020-08-18/protect_against_invalid_ids_in_import_delete-3051453-10.patch"
            },
            "drupal/menu_migration": {
                "Local patch | Support languages in menu export": "patches/menu_migration-language-support.patch"
            },
            "drupal/password_policy": {
                "Local patch | Fix file permission to avoid grumphp validation error": "patches/password-policy-test-script-file-permission.patch"
            }
        },
        "dropin-paths": {
            "web/": [
                "type:web-dropin"
            ]
        }
    }
}
